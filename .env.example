# Environment
# Set to 'production' for production builds
NODE_ENV=development

# Server Configuration
PORT=4100

# Commerce Suite API Configuration
# Base URL for Commerce Suite API endpoints
# All API calls will be proxied through Next.js server routes
CS_API_BASE_URL=http://localhost:3000

# Commerce Suite Authentication
# App Key and Secret Key for authenticating with Commerce Suite API
CS_APP_KEY=your_app_key_here
CS_SECRET_KEY=your_secret_key_here

# Google Maps API Key (required for Locations page map)
# Get key from: https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_api_key_here
